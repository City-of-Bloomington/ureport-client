{
    "require": {
        "php": ">=8.5",
        "aura/di":              "@stable",
        "aura/router":          "@stable",
        "apereo/phpcas":        "@stable",
        "google/recaptcha":     "@stable",
        "guzzlehttp/guzzle":    "@stable",
        "graylog2/gelf-php":    "@stable",
        "twig/twig":            "@stable"
    },
    "require-dev": {
        "phpunit/phpunit":      "@stable"
    },
    "autoload": {
        "psr-4": {
            "Web\\":    "src/Web",
            "Domain\\": "src/Domain"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\": "src/Test"
        }
    }
}
